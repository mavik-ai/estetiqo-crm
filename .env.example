# ============================================
# ESTETIQO CRM - CONFIGURAÇÕES DE AMBIENTE
# ============================================
# Cópia deste arquivo deve ser renomeada para `.env`
# NUNCA commite o arquivo `.env` com valores reais.

# ============================================
# 1. SUPABASE (Banco de dados, Auth, Storage)
# ============================================
# Encontrado em: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Encontrado em: Project Settings -> Database (Role: postgres)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================
# 2. EVOLUTION API (WhatsApp RSVP)
# ============================================
EVOLUTION_API_URL=https://api.whatsapp.estetiqo.com.br
EVOLUTION_API_TOKEN=your_evolution_global_token
EVOLUTION_INSTANCE_NAME=estetiqo_principal

# ============================================
# 3. PAGAMENTOS (Stripe e Hotmart)
# ============================================
# STRIPE
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# HOTMART
HOTMART_WEBHOOK_TOKEN=your_hotmart_webhook_token

# ============================================
# 4. APLICAÇÃO (Frontend e Backend)
# ============================================
# Frontend (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend (FastAPI)
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 horas

# ============================================
# 5. N8N (Agente Camila e Webhooks)
# ============================================
N8N_WEBHOOK_URL=https://n8n.estetiqo.com.br/webhook
N8N_API_KEY=your_n8n_api_key
